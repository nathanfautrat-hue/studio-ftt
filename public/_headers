# Cloudflare Pages — custom headers
# Force les fichiers .md à s'afficher en clair dans le navigateur (pas en download)
/*.md
  Content-Type: text/plain; charset=utf-8
  X-Robots-Tag: index, follow

/projets/*.md
  Content-Type: text/plain; charset=utf-8
  X-Robots-Tag: index, follow

# Force le llms.txt en text/plain aussi (sécurité)
/llms.txt
  Content-Type: text/plain; charset=utf-8
  X-Robots-Tag: index, follow

# Pages utilitaires : noindex (pas dans les SERPs)
/og-image-source.html
  X-Robots-Tag: noindex, nofollow

# Démos clients : noindex (pas dans les SERPs principales)
/demo/*
  X-Robots-Tag: noindex, follow

# Headers globaux de sécurité (signal SEO + sécurité)
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
