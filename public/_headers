# Cloudflare Pages — custom headers
# Force les fichiers .md à s'afficher en clair dans le navigateur (pas en download)
/*.md
  Content-Type: text/plain; charset=utf-8
  X-Robots-Tag: index, follow

/projets/*.md
  Content-Type: text/plain; charset=utf-8
  X-Robots-Tag: index, follow

# Force le llms.txt en text/plain aussi (sécurité)
/llms.txt
  Content-Type: text/plain; charset=utf-8
  X-Robots-Tag: index, follow

# Pages utilitaires : noindex (pas dans les SERPs)
/og-image-source.html
  X-Robots-Tag: noindex, nofollow

# Démos clients : noindex (pas dans les SERPs principales)
/demo/*
  X-Robots-Tag: noindex, follow

# Chunks Next.js : immutables (hash dans le nom), cache 1 an (navigateur + edge)
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
  ! Cloudflare-CDN-Cache-Control
  Cloudflare-CDN-Cache-Control: public, max-age=31536000, immutable

# Pages HTML : pas de cache navigateur → évite l'erreur "ChunkLoadError"
# après un nouveau déploiement (le HTML pointait vers un vieux chunk supprimé)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Headers globaux de sécurité (signal SEO + sécurité)
# Cloudflare-CDN-Cache-Control: no-store = l'edge Cloudflare ne stocke pas les pages
# → chaque déploiement est visible immédiatement, plus de purge manuelle
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cache-Control: public, max-age=0, must-revalidate
  Cloudflare-CDN-Cache-Control: no-store
